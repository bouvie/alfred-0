  "scripts": {
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:tools": "docker compose -f docker/docker-compose.yml --profile tools up -d",
    "db:migrate": "prisma migrate deploy --schema=libs/database/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=libs/database/prisma/schema.prisma",
    "db:seed": "ts-node libs/database/prisma/seed.ts",
    "db:studio": "prisma studio --schema=libs/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=libs/database/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "libs/database/prisma/schema.prisma"
  },
  "private": true,
